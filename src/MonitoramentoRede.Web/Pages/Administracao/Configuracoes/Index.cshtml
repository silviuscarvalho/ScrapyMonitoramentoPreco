@page
@model MonitoramentoRede.Web.Pages.Administracao.Configuracoes.IndexModel
@{
    ViewData["Title"] = "Configurações";
}

<div class="painel">
    <form method="post" class="row g-3">
        <input asp-for="Configuracao.Id" type="hidden" />
        <div class="col-md-6"><label class="form-label">Chave da API interna</label><input asp-for="Configuracao.ChaveApiInterna" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Retenção (dias)</label><input asp-for="Configuracao.RetencaoDadosDias" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Atualização dashboard (s)</label><input asp-for="Configuracao.IntervaloAtualizacaoDashboardSegundos" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label">Limite pico tráfego (bytes)</label><input asp-for="Configuracao.LimitePicoTrafegoBytes" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label">Janela excesso DNS (min)</label><input asp-for="Configuracao.JanelaExcessoDnsMinutos" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label">Limite consultas DNS</label><input asp-for="Configuracao.LimiteConsultasDnsJanela" class="form-control" /></div>
        <div class="col-md-12"><label class="form-label">Portas incomuns</label><input asp-for="Configuracao.PortasIncomuns" class="form-control" /></div>
        <div class="col-12"><button type="submit" class="btn btn-primary">Salvar configurações</button></div>
    </form>
</div>
